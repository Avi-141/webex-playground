# Webex API token (personal access token for testing, bot/OAuth for production)
WEBEX_TOKEN=

# Comma-separated Webex Room IDs (run `npm run list-spaces` to find them)
WEBEX_ROOM_IDS=

# SQLite database path
DB_PATH=./webex.db

# Thread documents output path
THREADS_PATH=./threads.json

# Ollama endpoint (localhost if running natively, host.docker.internal if Ollama is on host and client is in container)
OLLAMA_URL=http://localhost:11434

# Embedding model name (must be pulled in Ollama first)
EMBED_MODEL=nomic-embed-text
